# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Python version file (managed by pyenv)
.python-version

# Model files (large binary files)
*.pt
*.onnx
*.h5
*.weights

# Output results (generated at runtime)
results/*.jpg
results/*.png
results/*.mp4

# Environment variables
.env
.env.local
.env.*.local

# IDE and editor configurations
.vscode/
.idea/
*.swp
*.swo
*~

# OS-specific files
.DS_Store
Thumbs.db

# Cache directories
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Logs
*.log
logs/

# Temporary files
*.tmp
*.bak
*.swpbus.jpg
zidane.jpg
